  34   2              }
  35   1              RCK=1;
  36   1              RCK=0;
  37   1      }
  38          /**
  39             * @brief  LCD点阵屏显示一列数据
  40             * @param  Column 选择列，范围0~7，0在最左
  41             * @param  Data 选择列的数据，高位在最上，1为亮，0为灭
  42             * @retval
  43             */           
  44          void MatrixLED_ShowColumn(unsigned char Column,Data)
  45          {
  46   1              _74HC595_WriteByte(Data);
