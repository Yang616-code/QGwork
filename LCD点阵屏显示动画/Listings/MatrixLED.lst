line level    source

   1          #include <REGX52.H>
   2          #include "Delay.h"
   3          
   4          sbit RCK=P3^5;
   5          sbit SCK=P3^6;
   6          sbit SER=P3^4;
   7          
   8          #define MATRTX_LED_PORT                 P0
   9          
  10          /**
  11             * @brief  点阵屏初始化
  12             * @param  无
  13             * @retval 无
  14             */           
  15          void MatrixLED_Init()
  16          {
  17   1              SCK=0;
  18   1              RCK=0;
  19   1      }
  20          
  21          /**
  22             * @brief  74HC95写入一个字节
  23             * @param  要写的字节
  24             * @retval 无
  25             */           
  26          void _74HC595_WriteByte(unsigned char Byte)
  27          {
  28   1              unsigned char i;
  29   1              for(i=0;i<8;i++)
  30   1              {
  31   2                      SER=Byte&(0x80>>i);
